*.meta

# Compiled/intermediate
*.dll
*.so
*.dylib
*.bundle
*.wasm
*.wasm.br
*.data
*.data.br

# Packages and third-party (read via docs, not source)
Packages/
Assets/Plugins/
Assets/TextMesh Pro/

# Unity generated
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/
MemoryCaptures/

# IDE
.idea/
.vs/
.vscode/

# Project settings (binary-ish YAML, rarely useful)
ProjectSettings/
